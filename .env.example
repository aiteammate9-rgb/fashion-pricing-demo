# Required for AI-assisted production demo
OPENAI_API_KEY=
JWT_SECRET=replace-with-a-long-random-secret

# Optional: persistent database. If omitted, the app can still run in demo/fallback mode depending on current storage configuration.
DATABASE_URL=

# Optional: additional pricing/AI providers
RETAILED_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=

# Optional: OAuth / owner configuration for authenticated production mode
VITE_APP_ID=
OAUTH_SERVER_URL=
OWNER_OPEN_ID=

# Image storage (Cloudinary) — replaces Manus Forge storage
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# LINE Login (developers.line.biz → LINE Login channel)
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=
LINE_CALLBACK_URL=http://localhost:3000/api/line/callback
